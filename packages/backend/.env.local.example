# Local backend development
# Copy to `.env.local` inside `packages/backend`.

PORT=4000
DATABASE_URL=postgres://erp_user:erp_password@localhost:5433/erp
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EXPOSE_2FA_CODE=false
TWO_FACTOR_DEFAULT_CHANNEL=WHATSAPP
GOOGLE_CLIENT_ID=
TWO_FACTOR_PHONE_OVERRIDE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Use E.164 for SMS/VOICE or `whatsapp:+14155238886` for WhatsApp Sandbox/sender.
TWILIO_FROM_PHONE=whatsapp:+14155238886
# Required for business-initiated WhatsApp 2FA in Sandbox or with an approved template.
TWILIO_WHATSAPP_CONTENT_SID=

DEMO_USER_USERNAME=admin
DEMO_USER_NAME=Administrador ERP
DEMO_USER_EMAIL=admin@erp.local
DEMO_USER_PASSWORD=Admin123*
DEMO_USER_ROLE_ID=1
DEMO_USER_2FA_ENABLED=true
