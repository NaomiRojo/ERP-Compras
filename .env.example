# Docker Compose environment
# Copy to `.env` if you need to recreate the root Docker configuration.

POSTGRES_DB=erp
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password

DATABASE_URL=postgres://erp_user:erp_password@db:5432/erp
DB_HOST=db
DB_PORT=5432
DB_NAME=erp
DB_USER=erp_user
DB_PASSWORD=erp_password

JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000
EXPOSE_2FA_CODE=true
GOOGLE_CLIENT_ID=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TWO_FACTOR_EMAIL_OVERRIDE=
