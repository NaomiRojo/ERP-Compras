# Docker Compose environment
# Copy to `.env` if you need to recreate the root Docker configuration.

POSTGRES_DB=erp
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password

DATABASE_URL=postgres://erp_user:erp_password@db:5432/erp
DB_HOST=db
DB_PORT=5432
DB_NAME=erp
DB_USER=erp_user
DB_PASSWORD=erp_password

JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
EXPOSE_2FA_CODE=false
TWO_FACTOR_DEFAULT_CHANNEL=
GOOGLE_CLIENT_ID=
TWO_FACTOR_PHONE_OVERRIDE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Use E.164 for SMS/VOICE or `whatsapp:+14155238886` for WhatsApp Sandbox/sender.
TWILIO_FROM_PHONE=
# Required for business-initiated WhatsApp 2FA in Sandbox or with an approved template.
TWILIO_WHATSAPP_CONTENT_SID=
